import streamlit as st
import subprocess
import re
import tempfile
from reportlab.lib.pagesizes import A4
from reportlab.pdfgen import canvas
from reportlab.lib.units import mm

# -----------------------------
# Check Ollama Installation
# -----------------------------
def check_ollama():
    try:
        subprocess.run(
            ["ollama", "--version"],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=True
        )
    except Exception:
        st.error("❌ Ollama is not installed or not in PATH")
        st.stop()

# -----------------------------
# Clean LLM Output
# -----------------------------
def clean_text(text):
    text = re.sub(r"(?i)sure.*?:", "", text)
    text = re.sub(r"\*\*", "", text)
    return text.strip()

# -----------------------------
# Generate Descriptive Questions
# -----------------------------
def generate_questions(unit_text, unit_no):

    questions = []

    bloom_map = [
        ("L2", "Medium", "Apply concepts"),
        ("L3", "Hard", "Analyze and Evaluate concepts")
    ]

    for idx, (bloom, difficulty, bloom_desc) in zip(['a', 'b'], bloom_map):

        prompt = f"""
You are an EXPERIENCED UNIVERSITY PROFESSOR creating an OFFICIAL exam paper.

TASK:
Generate ONE descriptive theory question worth 13 marks.

STRICT RULES:
- No spelling mistakes
- Grammatically perfect
- No programming or coding questions
- Academic university exam standard
- Must test conceptual understanding
- Follow Bloom’s taxonomy strictly
- Do NOT explain anything
- Output ONLY the question sentence

Bloom Level: {bloom} ({bloom_desc})
Difficulty Level: {difficulty}

Unit {unit_no} syllabus:
{unit_text}
"""

        process = subprocess.run(
            ["ollama", "run", "gemma:2b"],  # Change to mistral/llama3 if installed
            input=prompt.encode("utf-8"),
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE
        )

        raw = process.stdout.decode("utf-8", errors="ignore")
        clean = clean_text(raw)

        questions.append(f"({idx}) ({bloom} – {difficulty}) {clean}")

    return questions


# -----------------------------
# Generate MCQs
# -----------------------------
def generate_mcqs(unit_text):

    prompt = f"""
You are a UNIVERSITY EXAMINER.

Generate EXACTLY 10 Multiple Choice Questions.

RULES:
- No mistakes
- Academic style
- No coding questions
- Each question must have 4 options (A,B,C,D)
- Mention the correct answer after each question
- Do NOT add explanations

FORMAT STRICTLY:

1. Question
A.
B.
C.
D.
Answer: X
--------------------------------

Unit syllabus:
{unit_text}
"""

    process = subprocess.run(
        ["ollama", "run", "gemma:2b"],
        input=prompt.encode("utf-8"),
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE
    )

    raw = process.stdout.decode("utf-8", errors="ignore")
    return clean_text(raw)


# -----------------------------
# Descriptive PDF
# -----------------------------
def generate_pdf(all_questions):

    temp_file = tempfile.NamedTemporaryFile(delete=False, suffix=".pdf")
    c = canvas.Canvas(temp_file.name, pagesize=A4)

    width, height = A4
    margin = 20 * mm
    y = height - margin

    c.setFont("Times-Bold", 16)
    c.drawCentredString(width / 2, y, "UNIVERSITY EXAMINATION")
    y -= 30

    c.setFont("Times-Roman", 12)
    c.drawString(margin, y, "Answer ALL questions (13 Marks each)")
    y -= 25

    for i, unit in enumerate(all_questions, start=1):

        c.setFont("Times-Bold", 12)
        c.drawString(margin, y, f"Unit {i} – 13 Marks")
        y -= 18

        for q in [unit[0], "OR", unit[1]]:

            if q == "OR":
                c.drawCentredString(width / 2, y, "OR")
                y -= 20
                continue

            c.setFont("Times-Roman", 12)

            words = q.split()
            line = ""

            for word in words:
                if c.stringWidth(line + " " + word, "Times-Roman", 12) < (width - 2 * margin):
                    line += " " + word
                else:
                    c.drawString(margin, y, line.strip())
                    y -= 14
                    line = word

            if line:
                c.drawString(margin, y, line.strip())
                y -= 18

        y -= 10

        if y < margin:
            c.showPage()
            y = height - margin

    c.save()
    return temp_file.name


# -----------------------------
# MCQ PDF
# -----------------------------
def generate_mcq_pdf(mcq_text):

    temp_file = tempfile.NamedTemporaryFile(delete=False, suffix=".pdf")
    c = canvas.Canvas(temp_file.name, pagesize=A4)

    width, height = A4
    margin = 20 * mm
    y = height - margin

    c.setFont("Times-Bold", 16)
    c.drawCentredString(width / 2, y, "MCQ QUESTION PAPER")
    y -= 30

    c.setFont("Times-Roman", 11)

    lines = mcq_text.split("\n")

    for line in lines:

        if y < margin:
            c.showPage()
            y = height - margin

        # wrap long lines
        while len(line) > 95:
            c.drawString(margin, y, line[:95])
            line = line[95:]
            y -= 14

        c.drawString(margin, y, line)
        y -= 14

    c.save()
    return temp_file.name


# -----------------------------
# STREAMLIT UI
# -----------------------------
st.set_page_config(page_title="BloomForge Question Generator", layout="centered")

st.title("📘 BloomForge: Smart Question Paper Generator")

check_ollama()

exam_type = st.radio(
    "Select Exam Type",
    ["Descriptive Question Paper", "MCQ Generator"]
)

units_input = []

# -----------------------------
# INPUT UI
# -----------------------------
if exam_type == "Descriptive Question Paper":

    st.write("Enter **5 Units Syllabus**")

    for i in range(1, 6):
        text = st.text_area(
            f"Unit {i} Syllabus",
            height=120,
            placeholder="Enter syllabus topics..."
        )
        units_input.append(text)

else:

    unit_text = st.text_area(
        "Enter Unit Syllabus for MCQ",
        height=200,
        placeholder="Enter full unit topics..."
    )

# -----------------------------
# GENERATE BUTTON
# -----------------------------
if st.button("🎯 Generate"):

    # ---------- Descriptive ----------
    if exam_type == "Descriptive Question Paper":

        if any(unit.strip() == "" for unit in units_input):
            st.warning("⚠️ Please fill all 5 unit syllabus fields")

        else:

            with st.spinner("Generating university-level questions..."):

                all_questions = []
                for i, unit in enumerate(units_input, start=1):
                    all_questions.append(generate_questions(unit, i))

                pdf_path = generate_pdf(all_questions)

            with open(pdf_path, "rb") as f:
                st.success("✅ Question Paper Generated Successfully")

                st.download_button(
                    label="⬇️ Download Question Paper (PDF)",
                    data=f,
                    file_name="Bloom_Question_Paper.pdf",
                    mime="application/pdf"
                )

    # ---------- MCQ ----------
    else:

        if unit_text.strip() == "":
            st.warning("⚠️ Please enter syllabus")

        else:

            with st.spinner("Generating MCQs..."):

                mcq_text = generate_mcqs(unit_text)
                pdf_path = generate_mcq_pdf(mcq_text)

            with open(pdf_path, "rb") as f:
                st.success("✅ MCQ Paper Generated")

                st.download_button(
                    label="⬇️ Download MCQ PDF",
                    data=f,
                    file_name="MCQ_Question_Paper.pdf",
                    mime="application/pdf"
                )
